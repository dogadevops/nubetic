---
import CheckIcon from "./CheckIcon.astro";
interface Props {
  lang?: string;
}

const { lang = "es" } = Astro.props;
const t = await import(`../i18n/${lang}.json`);
const translations = t.default;

// Extraemos los datos específicos para mayor limpieza
const { title, description, subtitle, paragraph1, subtitle2, benefits, image } = translations.testimonials;
---

<section id="testimonials" class="py-24 bg-white dark:bg-gray-900">
  <div class="container mx-auto px-4">
    
    <div class="reveal text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-white mb-4">
        {title}
      </h2>
      <p class="text-xl text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
        {description}
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      
      <div class="reveal lg:col-span-5 space-y-6">
        <div>
          <h3 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-4">
            {subtitle}
          </h3>
          <p class="text-lg text-justify text-gray-600 dark:text-gray-400 leading-relaxed" set:html={paragraph1} />
        </div>

        <div class="space-y-4">
          <h3 class="text-2xl font-bold text-gray-900 dark:text-white">
            {subtitle2}
          </h3>
          
          <div class="grid gap-3">
            {benefits.map((item: string) => (
              <div class="flex items-center gap-3">
                <CheckIcon class="w-6 h-6 text-blue-600" />
                <p class="text-gray-700 dark:text-gray-300 font-medium">
                  {item}
                </p>
              </div>
            ))}
          </div>
        </div>
      </div>

      <div class="reveal lg:col-span-7 flex justify-center rounded-lg overflow-hidden shadow-lg">
        <img
          src={image}
          alt={`Imagen ilustrativa de ${title}`}
          class="w-full h-auto max-w-4xl" 
        />
      </div>
    </div>
  </div>
</section>