---
interface Props {
  lang?: string;
}

const { lang = "es" } = Astro.props;
const t = await import(`../i18n/${lang}.json`);
const translations = t.default;

const testimonials = Object.values(translations.testimonials.items);
---

<section id="testimonials" class="py-24 bg-white dark:bg-gray-900">
  <div class="container mx-auto px-4">
    <div class="text-center mb-16">
      <h2
        class="text-4xl md:text-3xl font-bold text-gray-900 dark:text-white mb-4"
      >
        {translations.testimonials.title}
      </h2>
      <p class="text-xl text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
        Una Suite con todo lo que necesita su empresa, todo en un solo lugar
      </p>
    </div>

    <div class="grid grid-cols-1 md:[grid-template-columns:35%_30%_35%] gap-6">

      <div class="reveal p-8 rounded-2xl bg-gray-50 dark:bg-gray-800 border border-gray-100 dark:border-gray-700">
        <div class="text-center flex items-center gap-2 mb-4">
          <h2 class="text-4xl md:text-2xl font-bold text-gray-900 dark:text-white mb-4" >
            Archivos de Nextcloud
          </h2>
        </div>
        <p class="text-gray-600 dark:text-gray-300 mb-6 italic">yo</p>
        <div class="flex items-center gap-4">
          <div>
            <div class="text-sm text-gray-500 dark:text-gray-400">
              <p>1</p>
            </div>
          </div>
        </div>
      </div>

      <div class="reveal p-8 rounded-2xl bg-gray-50 dark:bg-gray-800 border border-gray-100 dark:border-gray-700">
        <div class="flex items-center gap-1 mb-4"></div>
        <p class="text-gray-600 dark:text-gray-300 mb-6 italic">yo</p>
        <div class="flex items-center gap-4">
          <div>
            <div class="text-sm text-gray-500 dark:text-gray-400">
              <p>2</p>
            </div>
          </div>
        </div>
      </div>

      <div
        class="reveal p-8 rounded-2xl bg-gray-50 dark:bg-gray-800 border border-gray-100 dark:border-gray-700"
      >
        <div class="flex items-center gap-1 mb-4"></div>
        <p class="text-gray-600 dark:text-gray-300 mb-6 italic">yo</p>
        <div class="flex items-center gap-4">
          <div>
            <div class="text-sm text-gray-500 dark:text-gray-400">
              <p></p>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
