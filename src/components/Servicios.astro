---
interface Props {
  lang?: string;
}

const { lang = 'es' } = Astro.props;

const translations = {
  es: {
    badge: "🚀 Servicios",
    title: "Soluciones en la nube para cada necesidad",
    description: "Ofrecemos una gama completa de servicios de almacenamiento y gestión de datos en la nube, diseñados para impulsar tu productividad y proteger tu información.",
    subtitle: "Elige el servicio que necesitas",
    storageTitle: "Almacenamiento y Sincronización",
    storageSubtitle: "Powered by Nextcloud-OVH",
    storageDescription: "Almacenamiento seguro, sincronización de archivos, colaboración en tiempo real y aplicaciones de productividad. Todo lo que necesitas para trabajar en equipo.",
    storageFeatures: ["Desde 250 GB hasta 504 TB", "Sincronización multi-dispositivo", "Colaboración en tiempo real", "Apps de productividad Nextcloud", "Soporte 24/7 con IA"],
    storageIcon: "☁️",
    mailTitle: "Correo Corporativo",
    mailSubtitle: "Powered by Zimbra",
    mailDescription: "Plataforma de correo empresarial completa con calendario, contactos, tareas y colaboración. La solución profesional que tu empresa necesita.",
    mailFeatures: ["Desde 30 GB hasta 3 TB", "Dominios ilimitados", "Calendario y contactos compartidos", "Seguridad avanzada SSL/TLS", "Antispam y antivirus"],
    mailIcon: "📧",
    buttonStorage: "Ver Planes",
    buttonMail: "Ver Planes"
  },
  en: {
    badge: "🚀 Services",
    title: "Cloud solutions for every need",
    description: "We offer a complete range of cloud storage and data management services, designed to boost your productivity and protect your information.",
    subtitle: "Choose the service you need",
    storageTitle: "Storage and Sync",
    storageSubtitle: "Powered by Nextcloud-OVH",
    storageDescription: "Secure file storage, synchronization, real-time collaboration and productivity applications. Everything you need to work as a team.",
    storageFeatures: ["From 250 GB to 504 TB", "Multi-device sync", "Real-time collaboration", "Nextcloud productivity apps", "24/7 Support with AI"],
    storageIcon: "☁️",
    mailTitle: "Business Email",
    mailSubtitle: "Powered by Zimbra",
    mailDescription: "Complete business email platform with calendar, contacts, tasks and collaboration. The professional solution your company needs.",
    mailFeatures: ["From 30 GB to 3 TB", "Unlimited domains", "Shared calendar and contacts", "Advanced SSL/TLS security", "Antispam and antivirus"],
    mailIcon: "📧",
    buttonStorage: "View Plans",
    buttonMail: "View Plans"
  }
};

const t = translations[lang];
---

<section class="min-h-screen bg-gradient-to-b from-white to-gray-50 dark:from-gray-900 dark:to-gray-800 pt-32 pb-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    
    <!-- Badge -->
    <div class="mb-6 flex justify-center reveal">
      <span class="rounded-full bg-blue-100 px-4 py-2 text-sm font-medium text-blue-600 dark:bg-blue-900/30 dark:text-blue-400">
        {t.badge}
      </span>
    </div>

    <!-- Title & Description -->
    <div class="mb-16 text-center reveal">
      <h1 class="mb-6 text-4xl md:text-5xl font-bold tracking-tight text-gray-900 dark:text-white">
        {t.title}
      </h1>
      <p class="mx-auto max-w-3xl text-lg text-gray-600 dark:text-gray-300">
        {t.description}
      </p>
    </div>

    <!-- Service Selection -->
    <div class="mb-12 reveal">
      <div class="text-center mb-10">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white">{t.subtitle}</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        
        <!-- Storage Card -->
        <div class="group relative rounded-2xl bg-white dark:bg-gray-800 p-8 shadow-lg hover:shadow-2xl transition-all duration-300 hover:-translate-y-2 reveal">
        
          
          <!-- Title -->
          <h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-2">
            {t.storageIcon}
            {t.storageTitle}</h3>
          
          <!-- Badge -->
          <span class="inline-block px-3 py-1 rounded-full bg-blue-100 text-xs font-medium text-blue-600 dark:bg-blue-900/30 dark:text-blue-400 mb-4">
            {t.storageSubtitle}
          </span>

          <!-- Description -->
          <p class="text-gray-600 dark:text-gray-400 mb-6">
            {t.storageDescription}
          </p>

          <!-- Features -->
          <ul class="space-y-2 mb-8">
            {t.storageFeatures.map(feature => (
              <li class="flex items-start gap-2 text-sm text-gray-600 dark:text-gray-400">
                <svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                <span>{feature}</span>
              </li>
            ))}
          </ul>

          <!-- CTA Button -->
          <a
            href="/servicios/storage"
            class="block w-full text-center py-4 px-6 rounded-xl bg-blue-600 hover:bg-blue-700 text-white font-semibold transition-all shadow-md hover:shadow-lg"
          >
            {t.buttonStorage}
          </a>
        </div>

        <!-- Mail Card -->
        <div class="group relative rounded-2xl bg-white dark:bg-gray-800 p-8 shadow-lg hover:shadow-2xl transition-all duration-300 hover:-translate-y-2 reveal">
          <!-- Title -->

          <h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-2">
            {t.mailIcon}
            {t.mailTitle}
          </h3>
          
          
          <!-- Badge -->
          <span class="inline-block px-3 py-1 rounded-full bg-purple-100 text-xs font-medium text-purple-600 dark:bg-purple-900/30 dark:text-purple-400 mb-4">
            {t.mailSubtitle}
          </span>

          <!-- Description -->
          <p class="text-gray-600 dark:text-gray-400 mb-6">
            {t.mailDescription}
          </p>

          <!-- Features -->
          <ul class="space-y-2 mb-8">
            {t.mailFeatures.map(feature => (
              <li class="flex items-start gap-2 text-sm text-gray-600 dark:text-gray-400">
                <svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                <span>{feature}</span>
              </li>
            ))}
          </ul>

          <!-- CTA Button -->
          <a
            href="/servicios/mail"
            class="block w-full text-center py-4 px-6 rounded-xl bg-purple-600 hover:bg-purple-700 text-white font-semibold transition-all shadow-md hover:shadow-lg"
          >
            {t.buttonMail}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>