const t = translations[lang];
const plans = [t.plan1, t.plan2, t.plan3, t.plan4];

const colorClasses = {
  blue: {
    bg: "bg-blue-100 dark:bg-blue-900/30",
    text: "text-blue-600 dark:text-blue-400",
    border: "border-blue-200 dark:border-blue-800",
    button: "bg-blue-600 hover:bg-blue-700 dark:bg-blue-500 dark:hover:bg-blue-600",
    gradient: "from-blue-600 to-blue-700",
    icon: "bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400"
  },
  purple: {
    bg: "bg-purple-100 dark:bg-purple-900/30",
    text: "text-purple-600 dark:text-purple-400",
    border: "border-purple-200 dark:border-purple-800",
    button: "bg-purple-600 hover:bg-purple-700 dark:bg-purple-500 dark:hover:bg-purple-600",
    gradient: "from-purple-600 to-purple-700",
    icon: "bg-purple-100 dark:bg-purple-900/30 text-purple-600 dark:text-purple-400"
  },
  indigo: {
    bg: "bg-indigo-100 dark:bg-indigo-900/30",
    text: "text-indigo-600 dark:text-indigo-400",
    border: "border-indigo-200 dark:border-indigo-800",
    button: "bg-indigo-600 hover:bg-indigo-700 dark:bg-indigo-500 dark:hover:bg-indigo-600",
    gradient: "from-indigo-600 to-indigo-700",
    icon: "bg-indigo-100 dark:bg-indigo-900/30 text-indigo-600 dark:text-indigo-400"
  },
  violet: {
    bg: "bg-violet-100 dark:bg-violet-900/30",
    text: "text-violet-600 dark:text-violet-400",
    border: "border-violet-200 dark:border-violet-800",
    button: "bg-violet-600 hover:bg-violet-700 dark:bg-violet-500 dark:hover:bg-violet-600",
    gradient: "from-violet-600 to-violet-700",
    icon: "bg-violet-100 dark:bg-violet-900/30 text-violet-600 dark:text-violet-400"
  }
};
---

<section class="min-h-screen bg-gradient-to-b from-white to-gray-50 dark:from-gray-900 dark:to-gray-800 pt-32 pb-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    
    <!-- Badge -->
    <div class="mb-6 flex justify-center reveal">
      <span class="rounded-full bg-blue-100 px-4 py-2 text-sm font-medium text-blue-600 dark:bg-blue-900/30 dark:text-blue-400">
        {t.badge}
      </span>
    </div>

    <!-- Title & Description -->
    <div class="mb-16 text-center reveal">
      <h1 class="mb-6 text-4xl font-bold tracking-tight text-gray-900 dark:text-white md:text-5xl">
        {t.title}
      </h1>
      <p class="mx-auto max-w-3xl text-lg text-gray-600 dark:text-gray-300">
        {t.description}
      </p>
    </div>

    <!-- Plans Section -->
    <div class="mb-16 reveal">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">{t.plansTitle}</h2>
        <p class="text-gray-600 dark:text-gray-400">{t.plansSubtitle}</p>
      </div>

      <!-- Plans Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6">
        {plans.map((plan, index) => {
          const colors = colorClasses[plan.color as keyof typeof colorClasses];
          return (
            <div 
              class="group relative rounded-2xl bg-white dark:bg-gray-800 border {colors.border} p-6 shadow-lg hover:shadow-2xl transition-all duration-300 hover:-translate-y-2 reveal"
              style={`animation-delay: ${index * 100}ms`}
            >
              <!-- Popular Badge (for plan 4) -->
              {index === 3 && (
                <div class="absolute -top-3 left-1/2 -translate-x-1/2">
                  <span class="bg-gradient-to-r from-violet-600 to-purple-600 text-white text-xs font-bold px-4 py-1 rounded-full shadow-lg">
                    MÁS POPULAR
                  </span>
                </div>
              )}

              <!-- Plan Icon -->
              <div class={`w-14 h-14 ${colors.icon} rounded-xl flex items-center justify-center text-2xl mb-4 transition-transform group-hover:scale-110`}>
                {plan.icon}
              </div>

              <!-- Plan Title -->
              <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-1">{plan.title}</h3>
              <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">{plan.subtitle}</p>

              <!-- Features Preview -->
              <ul class="space-y-2 mb-6">
                {plan.features.slice(0, 4).map(feature => (
                  <li class="flex items-start gap-2 text-sm text-gray-600 dark:text-gray-400">
                    <svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                    </svg>
                    <span class="line-clamp-1">{feature}</span>
                  </li>
                ))}
                {plan.features.length > 4 && (
                  <li class="text-sm text-gray-400 dark:text-gray-500 italic">
                    + {plan.features.length - 4} más...
                  </li>
                )}
              </ul>

              <!-- CTA Button -->
              <a
                href={plan.href}
                class={`block w-full text-center py-3 px-4 rounded-xl text-white font-semibold ${colors.button} transition-all shadow-md hover:shadow-lg`}
              >
                Ver Plan
              </a>
            </div>
          );
        })}
      </div>
    </div>

  </div>
</section>
