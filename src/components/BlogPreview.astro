---
interface Props {
  lang?: string;
}

const { lang = 'es' } = Astro.props;
const t = await import(`../i18n/${lang}.json`);
const translations = t.default;

const blogPosts = [
  {
    title: lang === 'es' ? 'Cómo proteger tus datos en la nube' : 'How to protect your data in the cloud',
    excerpt: lang === 'es' ? 'Las mejores prácticas de seguridad para mantener tus archivos seguros.' : 'Best practices for keeping your files secure.',
    date: '2026-03-15',
    readTime: '5 min'
  },
  {
    title: lang === 'es' ? 'Colaboración en tiempo real' : 'Real-time collaboration',
    excerpt: lang === 'es' ? 'Trabaja con tu equipo de forma simultánea y eficiente.' : 'Work with your team simultaneously and efficiently.',
    date: '2026-03-10',
    readTime: '3 min'
  },
  {
    title: lang === 'es' ? 'Migración de datos sin interrupciones' : 'Seamless data migration',
    excerpt: lang === 'es' ? 'Guía paso a paso para迁移 a Nubetic.' : 'Step-by-step guide to migrating to Nubetic.',
    date: '2026-03-05',
    readTime: '7 min'
  }
];
---

<section id="blog" class="py-24 bg-white dark:bg-gray-900">
  <div class="container mx-auto px-4">
    <div class="text-center mb-16">
      <span class="inline-block px-4 py-2 bg-primary-100 dark:bg-primary-900/30 text-primary-600 dark:text-primary-400 rounded-full text-sm font-medium mb-4">
        {translations.blog.badge}
      </span>
      <h2 class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-white mb-4">
        {translations.blog.title}
      </h2>
      <p class="text-xl text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
        {translations.blog.description}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {blogPosts.map((post, index) => (
        <article class="reveal group cursor-pointer">
          <div class="p-6 rounded-2xl bg-gray-50 dark:bg-gray-800 border border-gray-100 dark:border-gray-700 hover:border-primary-500 dark:hover:border-primary-500 transition-all duration-300 hover:shadow-xl">
            <div class="text-sm text-primary-600 dark:text-primary-400 mb-2">
              {post.date} · {post.readTime}
            </div>
            <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-3 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">
              {post.title}
            </h3>
            <p class="text-gray-600 dark:text-gray-400">
              {post.excerpt}
            </p>
            <div class="mt-4 flex items-center text-primary-600 dark:text-primary-400 font-medium">
              {translations.blog.readMore}
              <svg class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>