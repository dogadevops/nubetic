---
interface Props {
  lang?: string;
}

const { lang = 'es' } = Astro.props;
const t = await import(`../i18n/${lang}.json`);
const translations = t.default;
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-gradient-to-br from-primary-50 via-white to-accent-50 dark:from-gray-900 dark:via-gray-800 dark:to-gray-900">
  <div class="absolute inset-0 overflow-hidden">
    <div class="absolute -top-40 -right-40 w-80 h-80 bg-primary-400/20 rounded-full blur-3xl animate-float"></div>
    <div class="absolute -bottom-40 -left-40 w-96 h-96 bg-accent-400/20 rounded-full blur-3xl animate-float" style="animation-delay: 1s;"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-gradient-to-r from-primary-500/10 to-accent-500/10 rounded-full blur-3xl"></div>
  </div>

  <div class="relative z-10 container mx-auto px-4 py-20">
    <div class="text-right max-w-4xl mx-auto">
      <span class="inline-block px-4 py-2 bg-white/80 dark:bg-gray-800/80 backdrop-blur-sm rounded-full text-sm font-medium text-primary-600 dark:text-primary-400 mb-6 glass animate-fade-in-up">
        {translations.hero.badge}
      </span>
      
      <h1 class="text-5xl md:text-7xl font-bold mb-6 animate-fade-in-up" style="animation-delay: 0.1s;">
        {translations.hero.title1} <span class="gradient-text">{translations.hero.title2}</span>
      </h1>
      
      <p class="text-xl text-center md:text-2xl text-gray-600 dark:text-gray-300 mb-10 max-w-2xl mx-auto animate-fade-in-up" style="animation-delay: 0.2s;">
        {translations.hero.description}
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center animate-fade-in-up" style="animation-delay: 0.3s;">
        <a href="#pricing" class="px-8 py-4 bg-primary-600 hover:bg-primary-700 text-white font-semibold rounded-xl transition-all duration-300 hover:scale-105 hover:shadow-lg hover:shadow-primary-500/25">
          {translations.hero.ctaPrimary}
        </a>
        <a href="#features" class="px-8 py-4 bg-white/80 dark:bg-gray-800/80 backdrop-blur-sm border border-gray-200 dark:border-gray-700 text-gray-700 dark:text-gray-200 font-semibold rounded-xl transition-all duration-300 hover:bg-white dark:hover:bg-gray-700 hover:scale-105 glass">
          {translations.hero.ctaSecondary}
        </a>
      </div>
    </div>
<!-- usuarios activos + tiempo activo + países -->
    <div class="grid grid-cols-3 gap-8 max-w-2xl mx-auto mt-20 pt-10 border-t border-gray-200/50 dark:border-gray-700/50 animate-fade-in-up" style="animation-delay: 0.4s;">
      <div class="text-center">
        <div class="text-3xl md:text-4xl font-bold gradient-text">50K+</div>
        <div class="text-sm text-gray-600 dark:text-gray-400 mt-1">{translations.hero.stats.users}</div>
      </div>
      <div class="text-center">
        <div class="text-3xl md:text-4xl font-bold gradient-text">99.9%</div>
        <div class="text-sm text-gray-600 dark:text-gray-400 mt-1">{translations.hero.stats.uptime}</div>
      </div>
      <div class="text-center">
        <div class="text-3xl md:text-4xl font-bold gradient-text">120+</div>
        <div class="text-sm text-gray-600 dark:text-gray-400 mt-1">{translations.hero.stats.countries}</div>
      </div>
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <a href="#features" class="w-6 h-10 border-2 border-gray-400 dark:border-gray-600 rounded-full flex justify-center pt-2">
      <div class="w-1 h-2 bg-gray-400 dark:bg-gray-600 rounded-full"></div>
    </a>
  </div>
</section>
