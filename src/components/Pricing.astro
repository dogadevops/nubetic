---
interface Props {
  lang?: string;
}

const { lang = 'es' } = Astro.props;
const t = await import(`../i18n/${lang}.json`);
const translations = t.default;

const plans = ['free', 'pro', 'enterprise'];
---

<section id="pricing" class="py-24 bg-gray-50 dark:bg-gray-800">
  <div class="container mx-auto px-4">
    <div class="text-center mb-16">
      <span class="inline-block px-4 py-2 bg-primary-100 dark:bg-primary-900/30 text-primary-600 dark:text-primary-400 rounded-full text-sm font-medium mb-4">
        {translations.pricing.badge}
      </span>
      <h2 class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-white mb-4">
        {translations.pricing.title}
      </h2>
      <p class="text-xl text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
        {translations.pricing.description}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-6xl mx-auto">
      {plans.map((plan, index) => {
        const isPopular = plan === 'pro';
        const planData = translations.pricing.plans[plan];
        
        return (
          <div class={`reveal relative rounded-2xl p-8 ${isPopular ? 'bg-white dark:bg-gray-900 border-2 border-primary-500 shadow-2xl shadow-primary-500/20' : 'bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700'}`}>
            {isPopular && (
              <div class="absolute -top-4 left-1/2 -translate-x-1/2">
                <span class="bg-gradient-to-r from-primary-500 to-accent-500 text-white px-4 py-1 rounded-full text-sm font-medium">
                  {translations.pricing.popular}
                </span>
              </div>
            )}
            
            <div class="text-center mb-8">
              <h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-2">
                {planData.name}
              </h3>
              <div class="flex items-baseline justify-center gap-1">
                <span class="text-5xl font-bold gradient-text">${planData.price}</span>
                <span class="text-gray-500 dark:text-gray-400">/mes</span>
              </div>
              <p class="text-gray-600 dark:text-gray-400 mt-2">{planData.description}</p>
            </div>

            <ul class="space-y-4 mb-8">
              {planData.features.map((feature: string) => (
                <li class="flex items-center gap-3 text-gray-600 dark:text-gray-300">
                  <svg class="w-5 h-5 text-primary-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                  </svg>
                  {feature}
                </li>
              ))}
            </ul>

            <a href="#contact" class={`block w-full py-4 rounded-xl text-center font-semibold transition-all duration-300 ${isPopular ? 'bg-primary-600 hover:bg-primary-700 text-white' : 'bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-primary-100 dark:hover:bg-primary-900/30'}`}>
              {translations.pricing.getStarted}
            </a>
          </div>
        );
      })}
    </div>
  </div>
</section>