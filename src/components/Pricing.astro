---
interface Props {
  lang?: string;
}

const { lang = "es" } = Astro.props;
const t = await import(`../i18n/${lang}.json`);
const translations = t.default;

const plans = ["free", "pro", "enterprise"];
---
<section id="pricing" class="relative min-h-screen flex items-center justify-center overflow-hidden bg-gradient-to-br from-primary-50 via-white to-accent-50 dark:from-gray-900 dark:via-gray-800 dark:to-gray-900">
 <div class="absolute inset-0 overflow-hidden">
    <div class="absolute -top-40 -right-40 w-80 h-80 bg-primary-400/20 rounded-full blur-3xl animate-float"></div>
    <div class="absolute -bottom-40 -left-40 w-96 h-96 bg-accent-400/20 rounded-full blur-3xl animate-float" style="animation-delay: 1s;"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-gradient-to-r from-primary-500/20 to-accent-500/20 rounded-full blur-2xl"></div>
  </div>
<!-- <section id="pricing" class="min-h-screen flex items-center py-24 bg-gray-50 dark:bg-gray-800 overflow-hidden"> -->
  <div class="container mx-auto px-4 max-w-7xl">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
      
      <div class="reveal lg:col-span-5 max-w-md mx-auto lg:max-w-none">
        <div class="relative rounded-2xl overflow-hidden shadow-2xl border border-gray-200 dark:border-gray-700 aspect-[8/5]">
          <img 
            src="/image_174d998a.png" 
            alt="Colaboración en equipo" 
            class="w-full h-full object-cover" 
          />
        </div>
      </div>

      <div class="reveal text-left lg:col-span-7 sm:pl-1">
        <h2 class="text-3xl md:text-2xl font-bold text-gray-900 dark:text-white mb-2 uppercase tracking-tight leading-tight">
          {translations.pricing.title}
        </h2>
        
        <p class="text-lg md:text-1xl text-gray-600 dark:text-gray-400 leading-relaxed">
          {translations.pricing.description}
        </p>
      </div>

    </div>
  </div>
</section>

