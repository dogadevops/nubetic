---

<section class="min-h-screen bg-gradient-to-b from-white to-gray-50 dark:from-gray-900 dark:to-gray-800 pt-32 pb-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    
    <!-- Badge -->
    <div class="mb-6 flex justify-center reveal">
      <span class="rounded-full bg-blue-100 px-4 py-2 text-sm font-medium text-blue-600 dark:bg-blue-900/30 dark:text-blue-400">
        {t.badge}
      </span>
    </div>

    <!-- Hero Section -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center mb-20">
      <div class="space-y-6 reveal">
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-white leading-none">
          {t.heroTitle}<span class="text-primary">{t.heroTitleHighlight}</span>
        </h1>
        <p class="text-lg text-gray-600 dark:text-gray-300 max-w-xl">
          {t.heroDescription}
        </p>
      </div>
      <div class="relative reveal">
       
          <div class="bg-blue-600 rounded-2xl overflow-hidden shadow-2xl flex flex-col md:flex-row items-center mb-20">
              <img src="/Zimbra.jpg"  />
         
          </div>
      
        <div class="absolute -bottom-6 -left-6 bg-white p-6 rounded-xl shadow-xl border border-gray-100 hidden md:block max-w-[240px]">
          <div class="flex items-center gap-3 mb-2">
            <div class="w-10 h-10 rounded-full bg-purple-100 flex items-center justify-center text-purple-600">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
              </svg>
            </div>
            <div class="font-semibold text-sm text-gray-900">{t.sslTitle}</div>
          </div>
          <p class="text-sm text-gray-500 leading-tight">{t.sslDescription}</p>
        </div>
      </div>
    </div>

    <!-- Why Zimbra Section -->
    <div class="mb-20 reveal">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">{t.zimbraTitle}</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {t.zimbraFeatures.map((feature, index) => (
          <div class="bg-white dark:bg-gray-800 p-6 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700 space-y-4 hover:shadow-md transition-shadow">
            <div class="w-12 h-12 rounded-lg bg-blue-50 text-blue-600 flex items-center justify-center">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={zimbraIcons[feature.icon] || zimbraIcons.storage}/>
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white">{feature.title}</h3>
            <p class="text-sm text-gray-500 dark:text-gray-400">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>

   

    <!-- Features Bento Grid -->
    <div class="mb-20 reveal">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">{t.featuresTitle}</h2>
        <p class="text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">{t.featuresSubtitle}</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {t.features.map((feature) => (
          <div class="bg-white dark:bg-gray-800 p-8 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700 space-y-4 hover:shadow-md transition-shadow">
            <div class="w-12 h-12 rounded-lg bg-blue-50 text-blue-600 flex items-center justify-center">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={zimbraIcons[feature.icon] || zimbraIcons.storage}/>
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white">{feature.title}</h3>
            <p class="text-sm text-gray-500 dark:text-gray-400">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Pricing Section -->
    <div class="mb-16 reveal">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">{t.pricingTitle}</h2>
        <p class="text-gray-600 dark:text-gray-400">{t.plansSubtitle}</p>
      </div>

      <!-- Plans Grid -->
      <div class="grid grid-cols-1 md:grid-cols-5 gap-1 max-w-7xl mx-auto">
        {plans.map((plan, index) => {
          const colors = colorClasses[plan.color as keyof typeof colorClasses];
          return (
            <div 
              class={`relative group rounded-2xl bg-white dark:bg-gray-800 p-6 shadow-lg hover:shadow-2xl transition-all duration-300 hover:-translate-y-2 reveal ${plan.featured ? 'ring-2 ring-blue-600' : ''}`}
              style={`animation-delay: ${index * 100}ms`}
            >
              {plan.featured && (
                <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-blue-600 text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-widest">
                  {t.recommended}
                </div>
              )}
              
              <!-- Plan Icon -->
              <div class={`w-14 h-14 ${colors.icon} rounded-xl flex items-center justify-center text-2xl mb-4 transition-transform group-hover:scale-110`}>
                {plan.icon}
              </div>

              <!-- Plan Title -->
              <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-1">{plan.name}</h3>
              <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">{plan.subtitle}</p>

              <!-- Features Preview -->
              <ul class="space-y-2 mb-6">
                {plan.features.map(feature => (
                  <li class="flex items-start gap-2 text-sm text-gray-600 dark:text-gray-400">
                    <svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                    </svg>
                    <span class="line-clamp-1">{feature}</span>
                  </li>
                ))}
              </ul>

              <!-- CTA Button -->
              <a
                href={plan.href}
                class={`block w-full text-center py-3 px-4 rounded-xl text-white font-semibold ${colors.button} transition-all shadow-md hover:shadow-lg`}
              >
                {t.buttonViewPlan}
              </a>
            </div>
          );
        })}
      </div>
    </div>
  </div>
</section>