</Layout>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    console.log('DOM loaded');
    
    const ADMIN_PASSWORD = 'NubeticAdmin2024!';
    const API_KEY = 'NubeticAdmin2024_SecureKey_abc123xyz789';
    
    var loginPanel = document.getElementById('login-panel');
    var adminPanel = document.getElementById('admin-panel');
    var passwordInput = document.getElementById('admin-password');
    var loginBtn = document.getElementById('login-btn');
    var loginError = document.getElementById('login-error');
    var logoutBtn = document.getElementById('logout-btn');
    var vbcInput = document.getElementById('vbc-input');
    var vbInput = document.getElementById('vb-input');
    var trwqDisplay = document.getElementById('trwq-display');
    var saveBtn = document.getElementById('save-btn');
    var saveSuccess = document.getElementById('save-success');
    var currentVbc = document.getElementById('current-vbc');
    var currentVb = document.getElementById('current-vb');
    var currentTrwq = document.getElementById('current-trwq');
    
    console.log('Elements found:', {loginPanel, adminPanel, saveBtn, vbcInput, vbInput});

    // Helper function to get auth header
    function getAuthHeader() {
      return 'Bearer ' + API_KEY;
    }
    
    async function loadValues() {
      console.log('Loading values from API...');
      try {
        var response = await fetch('/api/trwq', {
          headers: {
            'Authorization': getAuthHeader()
          }
        });
        console.log('Response status:', response.status);
        
        if (response.status === 401) {
          console.error('Unauthorized - Invalid API Key');
          return;
        }
        
        var data = await response.json();
        console.log('Data received:', data);
        
        var vbc = data.vbc || 1;
        var vb = data.vb || 1;
        var trwq = data.trwq || 1;
        
        vbcInput.value = vbc.toString();
        vbInput.value = vb.toString();
        trwqDisplay.textContent = trwq.toFixed(4);
        
        if (currentVbc) currentVbc.textContent = vbc.toFixed(2);
        if (currentVb) currentVb.textContent = vb.toFixed(2);
        if (currentTrwq) currentTrwq.textContent = trwq.toFixed(4);
        
        console.log('Values loaded successfully:', {vbc, vb, trwq});
      } catch (e) {
        console.error('Error loading config:', e);
      }
    }

    function calculateTrwq() {
      var vbc = parseFloat(vbcInput.value) || 1;
      var vb = parseFloat(vbInput.value) || 1;
      var trwq = vb / vbc;
      trwqDisplay.textContent = trwq.toFixed(4);
      return trwq;
    }

    // Cookie helpers (global)
    function setCookie(name, value, days) {
      var expires = '';
      if (days) {
        var date = new Date();
        date.setTime(date.getTime() + (days * 24 * 60 * 60 * 1000));
        expires = '; expires=' + date.toUTCString();
      }
      document.cookie = name + '=' + (value || '') + expires + '; path=/';
    }
    
    function getCookie(name) {
      var nameEQ = name + '=';
      var ca = document.cookie.split(';');
      for (var i = 0; i < ca.length; i++) {
        var c = ca[i];
        while (c.charAt(0) === ' ') c = c.substring(1, c.length);
        if (c.indexOf(nameEQ) === 0) return c.substring(nameEQ.length, c.length);
      }
      return null;
    }

    function login() {
      if (passwordInput.value === ADMIN_PASSWORD) {
        localStorage.setItem('nubetic_admin_logged', 'true');
        loginPanel.classList.add('hidden');
        adminPanel.classList.remove('hidden');
        loadValues();
      } else {
        loginError.classList.remove('hidden');
        passwordInput.value = '';
      }
    }

    function logout() {
      localStorage.removeItem('nubetic_admin_logged');
      adminPanel.classList.add('hidden');
      loginPanel.classList.remove('hidden');
      passwordInput.value = '';
      loginError.classList.add('hidden');
    }

    // Cookie helpers
    function setCookie(name, value, days) {
      var expires = '';
      if (days) {
        var date = new Date();
        date.setTime(date.getTime() + (days * 24 * 60 * 60 * 1000));
        expires = '; expires=' + date.toUTCString();
      }
      document.cookie = name + '=' + (value || '') + expires + '; path=/';
    }
    
    function getCookie(name) {
      var nameEQ = name + '=';
      var ca = document.cookie.split(';');
      for (var i = 0; i < ca.length; i++) {
        var c = ca[i];
        while (c.charAt(0) === ' ') c = c.substring(1, c.length);
        if (c.indexOf(nameEQ) === 0) return c.substring(nameEQ.length, c.length);
      }
      return null;
    }
    
    async function saveConfig() {
      var vbc = parseFloat(vbcInput.value) || 1;
      var vb = parseFloat(vbInput.value) || 1;
      
      console.log('=== SAVE CONFIG (API) ===');
      console.log('VBC:', vbc, 'VB:', vb);
      
      try {
        var response = await fetch('/api/trwq', {
          method: 'POST',
          headers: { 
            'Content-Type': 'application/json',
            'Authorization': getAuthHeader()
          },
          body: JSON.stringify({ vbc, vb })
        });
        
        console.log('Response status:', response.status);
        
        if (response.status === 401) {
          alert('Unauthorized - Invalid API Key');
          return;
        }
        
        if (response.status === 400) {
          var errorData = await response.json();
          alert('Error: ' + errorData.error);
          return;
        }
        
        if (!response.ok) {
          throw new Error('HTTP error! status: ' + response.status);
        }
        
        var data = await response.json();
        console.log('Saved data:', data);
        
        var trwq = data.trwq;
        console.log('Calculated TRWQ:', trwq);
        
        // Force reload the values from API to ensure we have latest
        await loadValues();
        
        // Also update inputs to match
        vbcInput.value = vbc.toString();
        vbInput.value = vb.toString();
        trwqDisplay.textContent = trwq.toFixed(4);
        
        console.log('UI updated with new values');
        
        // Show success message (no redirect)
        saveSuccess.classList.remove('hidden');
        
        setTimeout(function() {
          saveSuccess.classList.add('hidden');
        }, 3000);
      } catch (e) {
        console.error('Error saving config:', e);
        alert('Error al guardar: ' + e.message);
      }
    }

    // Check if already logged in
    if (localStorage.getItem('nubetic_admin_logged') === 'true') {
      loginPanel.classList.add('hidden');
      adminPanel.classList.remove('hidden');
      loadValues();
    }

    // Event listeners
    if (loginBtn) loginBtn.addEventListener('click', login);
    if (passwordInput) passwordInput.addEventListener('keypress', function(e) {
      if (e.key === 'Enter') login();
    });
    if (logoutBtn) logoutBtn.addEventListener('click', logout);
    if (vbcInput) vbcInput.addEventListener('input', calculateTrwq);
    if (vbInput) vbInput.addEventListener('input', calculateTrwq);
    if (saveBtn) {
      console.log('Adding click listener to saveBtn');
      saveBtn.addEventListener('click', saveConfig);
    }
  });
</script>
