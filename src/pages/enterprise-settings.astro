                  <tbody>
                    <tr class="border-b border-gray-700/50 hover:bg-gray-600/30"><td class="py-2 px-3 text-gray-300">36 TB</td><td class="py-2 px-3 text-right text-green-400 font-mono">550.00</td><td class="py-2 px-3 text-right text-green-400 font-mono">6,138.00</td><td class="py-2 px-3 text-right text-blue-400 font-mono">15.28</td></tr>
                    <tr class="border-b border-gray-700/50 hover:bg-gray-600/30"><td class="py-2 px-3 text-gray-300">56 TB</td><td class="py-2 px-3 text-right text-green-400 font-mono">790.00</td><td class="py-2 px-3 text-right text-green-400 font-mono">8,800.00</td><td class="py-2 px-3 text-right text-blue-400 font-mono">14.11</td></tr>
                    <tr class="border-b border-gray-700/50 hover:bg-gray-600/30"><td class="py-2 px-3 text-gray-300">84 TB</td><td class="py-2 px-3 text-right text-green-400 font-mono">1,100.00</td><td class="py-2 px-3 text-right text-green-400 font-mono">12,300.00</td><td class="py-2 px-3 text-right text-blue-400 font-mono">13.10</td></tr>
                    <tr class="border-b border-gray-700/50 hover:bg-gray-600/30"><td class="py-2 px-3 text-gray-300">112 TB</td><td class="py-2 px-3 text-right text-green-400 font-mono">1,400.00</td><td class="py-2 px-3 text-right text-green-400 font-mono">15,600.00</td><td class="py-2 px-3 text-right text-blue-400 font-mono">12.50</td></tr>
                    <tr class="border-b border-gray-700/50 hover:bg-gray-600/30"><td class="py-2 px-3 text-gray-300">336 TB</td><td class="py-2 px-3 text-right text-green-400 font-mono">2,500.00</td><td class="py-2 px-3 text-right text-green-400 font-mono">27,900.00</td><td class="py-2 px-3 text-right text-blue-400 font-mono">7.44</td></tr>
                    <tr class="hover:bg-gray-600/30"><td class="py-2 px-3 text-gray-300">504 TB</td><td class="py-2 px-3 text-right text-green-400 font-mono">3,250.00</td><td class="py-2 px-3 text-right text-green-400 font-mono">36,270.00</td><td class="py-2 px-3 text-right text-blue-400 font-mono">6.45</td></tr>
                  </tbody>
                </table>
              </div>
              <p class="text-xs text-gray-500 mt-3 italic">* Estos valores siempre fijos. Se multiplican por TRWQ en las páginas de servicios.</p>
            </div>

            <!-- Current Values -->
            <div class="bg-gray-700/30 rounded-xl p-4">
              <h4 class="text-xs font-semibold text-gray-400 mb-3 uppercase">Valores Actuales</h4>
              <div class="grid grid-cols-3 gap-2 text-sm">
                <div class="bg-gray-600/50 rounded p-2">
                  <p class="text-gray-400 text-xs">VBC</p>
                  <p id="current-vbc" class="text-white font-mono">1.00</p>
                </div>
                <div class="bg-gray-600/50 rounded p-2">
                  <p class="text-gray-400 text-xs">VB</p>
                  <p id="current-vb" class="text-white font-mono">1.00</p>
                </div>
                <div class="bg-gray-600/50 rounded p-2">
                  <p class="text-gray-400 text-xs">TRWQ</p>
                  <p id="current-trwq" class="text-green-400 font-mono">1.0000</p>
                </div>
              </div>
            </div>

            <!-- Success Message -->
            <p id="save-success" class="text-green-400 text-sm text-center hidden flex items-center justify-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              ¡Configuración guardada correctamente!
