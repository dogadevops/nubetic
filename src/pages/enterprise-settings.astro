---
import Layout from '../layouts/Layout.astro';

// Server-rendered (not static) para permitir POST
export const prerender = false;

const lang = 'es';
---

<Layout title="Nubetic - Enterprise" description="Enterprise Settings">
  <div class="min-h-screen bg-gray-900 flex items-center justify-center p-4">
    <div class="w-full max-w-md">
      <!-- Login Form -->
      <div id="login-panel" class="bg-gray-800 rounded-2xl p-8 shadow-2xl border border-gray-700">
        <div class="text-center mb-8">
          <div class="w-16 h-16 mx-auto mb-4 bg-blue-600 rounded-2xl flex items-center justify-center">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
            </svg>
          </div>
          <h1 class="text-2xl font-bold text-white mb-2">Panel Secreto</h1>
          <p class="text-gray-400 text-sm">Acceso restringido solo para administradores</p>
        </div>

        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-300 mb-2">Contraseña</label>
            <input 
              type="password" 
              id="admin-password"
              class="w-full bg-gray-700 border border-gray-600 rounded-lg px-4 py-3 text-white focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all"
              placeholder="••••••••"
            />
          </div>
          <button 
            id="login-btn"
            class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 rounded-lg transition-colors"
          >
            Acceder
          </button>
          <p id="login-error" class="text-red-400 text-sm text-center hidden">Contraseña incorrecta</p>
        </div>
      </div>

      <!-- Admin Panel (hidden by default) -->
      <div id="admin-panel" class="hidden">
        <div class="bg-gray-800 rounded-2xl p-8 shadow-2xl border border-gray-700">
          <div class="flex items-center justify-between mb-8">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-green-600 rounded-xl flex items-center justify-center">
                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                </svg>
              </div>
              <div>
                <h2 class="text-xl font-bold text-white">Configuración de Precios</h2>
                <p class="text-gray-400 text-xs">Sistema secreto de mark-up</p>
              </div>
            </div>
            <button id="logout-btn" class="text-gray-400 hover:text-white transition-colors">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
              </svg>
            </button>
          </div>

          <!-- Variables Section -->
          <div class="space-y-6">
            <div class="bg-gray-700/50 rounded-xl p-6">
              <h3 class="text-sm font-semibold text-gray-300 mb-4 uppercase tracking-wider">Variables de Cálculo</h3>
              
              <div class="grid grid-cols-2 gap-4 mb-6">
                <div>
                  <label class="block text-sm text-gray-400 mb-2">VBC (Costo Base)</label>
                  <input 
                    type="number" 
                    id="vbc-input"
                    class="w-full bg-gray-600 border border-gray-500 rounded-lg px-4 py-3 text-white focus:outline-none focus:ring-2 focus:ring-blue-500"
                    placeholder="1.0"
                    step="0.01"
                    min="0.01"
                  />
                  <p class="text-xs text-gray-500 mt-1">Valor base de referencia</p>
                </div>
                <div>
                  <label class="block text-sm text-gray-400 mb-2">VB (Valor de Venta)</label>
                  <input 
                    type="number" 
                    id="vb-input"
                    class="w-full bg-gray-600 border border-gray-500 rounded-lg px-4 py-3 text-white focus:outline-none focus:ring-2 focus:ring-blue-500"
                    placeholder="1.0"
                    step="0.01"
                    min="0.01"
                  />
                  <p class="text-xs text-gray-500 mt-1">Precio que ve el cliente</p>
                </div>
              </div>

              <div class="bg-blue-600/20 border border-blue-500/30 rounded-lg p-4">
                <div class="flex items-center justify-between">
                  <span class="text-sm text-gray-300">Factor TRWQ = VB / VBC</span>
                  <span id="trwq-display" class="text-2xl font-bold text-blue-400">1.0000</span>
                </div>
              </div>
            </div>

            <!-- Save Button -->
            <button 
